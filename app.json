{
  "expo": {
    "name": "Omnilingo",
    "slug": "omnilingo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "omnilingo",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.anhnqvo.omnilingo"
    },
    "android": {
      "backgroundColor": "#0f172a"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "baseUrl": "/Omnilingo"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e9a1d71b-393a-41cc-b8fd-5b1632c5a391"
      }
    },
    "owner": "anhnqvo",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e9a1d71b-393a-41cc-b8fd-5b1632c5a391"
    }
  }
}
